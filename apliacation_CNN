def make_edges(e_min, e_max, delta):
    return np.round(np.arange(e_min, e_max + delta / 2, delta), 6)


def binomial_error(n_pass, n_total):
    if n_total <= 0:
        return np.nan
    eff = n_pass / n_total
    return np.sqrt(eff * (1.0 - eff) / n_total)


def compute_efficiency(pred_df, edges, ycuts, group_cols):
    rows = []
    signals = pred_df[pred_df["population"].isin(SIGNAL_POPULATIONS)].copy()

    for keys, group in signals.groupby(group_cols):
        if not isinstance(keys, tuple):
            keys = (keys,)
        key_dict = dict(zip(group_cols, keys))

        for lo, hi in zip(edges[:-1], edges[1:]):
            g_bin = group[(group["BE"] >= lo) & (group["BE"] < hi)]
            n_total = len(g_bin)

            for ycut in ycuts:
                n_pass = int(np.sum(g_bin["score"].to_numpy() >= ycut))
                eff = n_pass / n_total if n_total else np.nan
                row = {
                    **key_dict,
                    "E_min": lo,
                    "E_max": hi,
                    "E_center": 0.5 * (lo + hi),
                    "ycut": ycut,
                    "n_total": n_total,
                    "n_pass": n_pass,
                    "efficiency": eff,
                    "efficiency_err": binomial_error(n_pass, n_total),
                }
                rows.append(row)

    return pd.DataFrame(rows)


def compute_mean_score(pred_df, edges, group_cols):
    rows = []
    signals = pred_df[pred_df["population"].isin(SIGNAL_POPULATIONS)].copy()

    for keys, group in signals.groupby(group_cols):
        if not isinstance(keys, tuple):
            keys = (keys,)
        key_dict = dict(zip(group_cols, keys))

        for lo, hi in zip(edges[:-1], edges[1:]):
            g_bin = group[(group["BE"] >= lo) & (group["BE"] < hi)]
            scores = g_bin["score"].to_numpy()
            rows.append({
                **key_dict,
                "E_min": lo,
                "E_max": hi,
                "E_center": 0.5 * (lo + hi),
                "n": len(scores),
                "mean_score": float(np.mean(scores)) if len(scores) else np.nan,
                "std_score": float(np.std(scores)) if len(scores) else np.nan,
            })

    return pd.DataFrame(rows)


def compute_corrected_rate(pred_df, eff_global, eff_det, edges, ycuts):
    rows_global = []
    rows_det = []
    test = pred_df[pred_df["population"] == "testtree_1_10"].copy()

    for lo, hi in zip(edges[:-1], edges[1:]):
        bin_width = hi - lo
        test_bin = test[(test["BE"] >= lo) & (test["BE"] < hi)]

        for ycut in ycuts:
            # Global: suma eventos de todos los detectores y usa masa total.
            n_pass = int(np.sum(test_bin["score"].to_numpy() >= ycut))
            eff_row = eff_global[
                (eff_global["population"] == "neutron_total_1_10")
                & (eff_global["E_min"] == lo)
                & (eff_global["ycut"] == ycut)
            ]
            eff = float(eff_row["efficiency"].iloc[0]) if len(eff_row) else np.nan
            eff_err = float(eff_row["efficiency_err"].iloc[0]) if len(eff_row) else np.nan

            exposure = MASS_DET_KG * len(DETECTORS) * LIVE_TIME_DAYS * bin_width
            rate = n_pass / (exposure * eff) if eff and eff > 0 else np.nan
            stat_err = np.sqrt(n_pass) / (exposure * eff) if n_pass > 0 and eff and eff > 0 else np.nan
            eff_part = rate * eff_err / eff if eff and eff > 0 and np.isfinite(eff_err) else np.nan
            total_err = np.sqrt(stat_err**2 + eff_part**2) if np.isfinite(stat_err) and np.isfinite(eff_part) else stat_err

            rows_global.append({
                "E_min": lo,
                "E_max": hi,
                "E_center": 0.5 * (lo + hi),
                "ycut": ycut,
                "n_pass": n_pass,
                "efficiency": eff,
                "rate_ckkd": rate,
                "rate_err": total_err,
            })

            # Por detector: mismo calculo con la masa de un detector.
            for det in DETECTORS:
                test_det = test_bin[test_bin["detector"] == det]
                n_det = int(np.sum(test_det["score"].to_numpy() >= ycut))
                eff_det_row = eff_det[
                    (eff_det["population"] == "neutron_total_1_10")
                    & (eff_det["detector"] == det)
                    & (eff_det["E_min"] == lo)
                    & (eff_det["ycut"] == ycut)
                ]
                eff_d = float(eff_det_row["efficiency"].iloc[0]) if len(eff_det_row) else np.nan
                exposure_d = MASS_DET_KG * LIVE_TIME_DAYS * bin_width
                rate_d = n_det / (exposure_d * eff_d) if eff_d and eff_d > 0 else np.nan

                rows_det.append({
                    "detector": det,
                    "E_min": lo,
                    "E_max": hi,
                    "E_center": 0.5 * (lo + hi),
                    "ycut": ycut,
                    "n_pass": n_det,
                    "efficiency": eff_d,
                    "rate_ckkd": rate_d,
                })

    return pd.DataFrame(rows_global), pd.DataFrame(rows_det)


edges_full = make_edges(E_FULL_MIN, E_FULL_MAX, DELTA_E)

