def read_hist(root_file, hist_name):
    with uproot.open(root_file) as f:
        values, edges = f[hist_name].to_numpy()
    centers = 0.5 * (edges[:-1] + edges[1:])
    return pd.DataFrame({"E_center": centers, "value": values})


def load_bdt_global():
    eff_parts = []
    rate_parts = []

    for det in DETECTORS:
        eff = read_hist(BDT_EFF_FILE, f"hbdt{det}")
        eff["detector"] = det
        eff_parts.append(eff)

        rate = read_hist(BDT_RATE_FILE, f"hneu{det}")
        rate["detector"] = det
        rate_parts.append(rate)

    eff_det_bdt = pd.concat(eff_parts, ignore_index=True)
    rate_det_bdt = pd.concat(rate_parts, ignore_index=True)

    eff_global_bdt = eff_det_bdt.groupby("E_center", as_index=False)["value"].mean().rename(columns={"value": "bdt_efficiency"})
    rate_global_bdt = rate_det_bdt.groupby("E_center", as_index=False)["value"].mean().rename(columns={"value": "bdt_rate"})

    eff_det_bdt.to_csv(TABLE_DIR / f"bdt_eficiencia_por_detector_{RUN_TAG}.tsv", sep="\t", index=False)
    rate_det_bdt.to_csv(TABLE_DIR / f"bdt_ritmo_por_detector_{RUN_TAG}.tsv", sep="\t", index=False)
    eff_global_bdt.to_csv(TABLE_DIR / f"bdt_eficiencia_global_media_detectores_{RUN_TAG}.tsv", sep="\t", index=False)
    rate_global_bdt.to_csv(TABLE_DIR / f"bdt_ritmo_global_media_detectores_{RUN_TAG}.tsv", sep="\t", index=False)

    return eff_global_bdt, rate_global_bdt


