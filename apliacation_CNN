def restrict_range(df, e_min, e_max):
    return df[(df["E_center"] >= e_min) & (df["E_center"] <= e_max)].copy()


def plot_efficiency_global(ycut, e_min, e_max, filename):
    fig, ax = plt.subplots(figsize=(8, 5))

    for pop in SIGNAL_POPULATIONS:
        g = eff_global[(eff_global["population"] == pop) & (eff_global["ycut"] == ycut)]
        g = restrict_range(g, e_min, e_max)
        if len(g):
            ax.errorbar(g["E_center"], g["efficiency"], yerr=g["efficiency_err"], marker="o", linestyle="-", label=pop)

    if len(bdt_eff_global):
        bdt = restrict_range(bdt_eff_global, e_min, e_max)
        ax.plot(bdt["E_center"], bdt["bdt_efficiency"], color="black", linewidth=2, label="BDT")

    ax.set_xlabel("Energia (keV)")
    ax.set_ylabel("Eficiencia")
    ax.set_ylim(-0.02, 1.05)
    ax.set_title(f"Eficiencia global, ycut={ycut}")
    ax.grid(alpha=0.3)
    ax.legend(fontsize=8)
    fig.tight_layout()
    fig.savefig(filename, dpi=200)
    plt.close(fig)


