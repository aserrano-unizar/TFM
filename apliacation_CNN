def plot_rate_global(e_min, e_max, filename):
    fig, ax = plt.subplots(figsize=(8, 5))

    for ycut in YCUT_VALUES:
        g = rate_global[rate_global["ycut"] == ycut]
        g = restrict_range(g, e_min, e_max)
        if len(g):
            ax.errorbar(g["E_center"], g["rate_ckkd"], yerr=g["rate_err"], marker="o", linestyle="-", label=f"CNN ycut={ycut}")

    if len(bdt_rate_global):
        bdt = restrict_range(bdt_rate_global, e_min, e_max)
        ax.plot(bdt["E_center"], bdt["bdt_rate"], color="black", linewidth=2, label="BDT")

    ax.set_xlabel("Energia (keV)")
    ax.set_ylabel("Ritmo corregido (cpd/kg/keV)")
