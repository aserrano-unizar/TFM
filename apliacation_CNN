# ============================================================
# Preprocesado de pulsos
# ============================================================

def branch_exists(tree, branch):
    # Comprueba si existe una rama.
    return branch in tree.keys()


def source_path(source, detector):
    # Construye la ruta ROOT para un detector.
    return DATA_DIR / source["pattern"].format(det=detector)


def downsample_waveform(w, factor=DOWNSAMPLING_FACTOR):
    # Promedia bloques de longitud factor.
    w = np.asarray(w, dtype=np.float32)
    if factor <= 1:
        return w
    n = (len(w) // factor) * factor
    return w[:n].reshape(-1, factor).mean(axis=1).astype(np.float32)


def window_until_end(signal, t0_pts, pre_samples, rms):
    # Extrae una ventana desde t0-pre_samples hasta el final esperado.
    n_final = pre_samples + (TOTAL_POINTS - TYPICAL_T0_PTS)
    start = int(t0_pts) - pre_samples

    pad_left = max(0, -start)
    idx_start = max(0, start)
    part_len = n_final - pad_left
    idx_end = min(len(signal), idx_start + part_len)

    part = signal[idx_start:idx_end]
    pad_right = max(0, n_final - (pad_left + len(part)))

    rms_safe = float(rms) if np.isfinite(rms) else 0.0
    left = np.random.normal(0, rms_safe, pad_left).astype(np.float32) if pad_left else np.empty(0, dtype=np.float32)
    right = np.random.normal(0, rms_safe, pad_right).astype(np.float32) if pad_right else np.empty(0, dtype=np.float32)

    window = np.concatenate([left, part.astype(np.float32), right]).astype(np.float32)
    if len(window) > n_final:
        window = window[:n_final]
    elif len(window) < n_final:
        window = np.pad(window, (0, n_final - len(window))).astype(np.float32)
    return window.astype(np.float32)


def normalize_pulses_max(w0, w1, pre_samples):
    # Normaliza los dos PMTs por el maximo absoluto comun tras el pretrigger.
    max0 = np.max(np.abs(w0[pre_samples:])) if len(w0[pre_samples:]) else 0.0
    max1 = np.max(np.abs(w1[pre_samples:])) if len(w1[pre_samples:]) else 0.0
    scale = max(max0, max1)
    if not np.isfinite(scale) or scale <= 0:
        scale = 1.0
    return w0 / scale, w1 / scale


def select_entries(root_path, source):
    # Selecciona eventos por energia y cortes de metadata.
    with uproot.open(root_path) as f:
        tree = f[TREE_NAME]
        n_total = tree.num_entries

        branches = ["BE"]
        for branch, _, _ in source.get("cuts", []):
            if branch not in branches:
                branches.append(branch)

        missing = [b for b in branches if not branch_exists(tree, b)]
        if missing:
            raise KeyError(f"Faltan ramas en {root_path}: {missing}")

        arrays = tree.arrays(branches, library="np", entry_start=0, entry_stop=n_total)
        emin, emax = source["energy_range"]
        mask = (arrays["BE"] >= emin) & (arrays["BE"] <= emax)

        for branch, op, value in source.get("cuts", []):
            if op == ">":
                mask &= arrays[branch] > value
            elif op == ">=":
                mask &= arrays[branch] >= value
            elif op == "<":
                mask &= arrays[branch] < value
            elif op == "<=":
                mask &= arrays[branch] <= value
            else:
                raise ValueError(f"Operador no reconocido: {op}")

    return np.flatnonzero(mask).astype(np.int64)


def read_events(root_path, detector, source, selected_entries):
    # Lee y preprocesa los eventos seleccionados.
    selected_entries = np.asarray(selected_entries, dtype=np.int64)
    pre_samples = int(PRE_NS * SRATE)
    n_time = (pre_samples + (TOTAL_POINTS - TYPICAL_T0_PTS)) // DOWNSAMPLING_FACTOR

    if selected_entries.size == 0:
        return np.empty((0, n_time, NUM_PMTS), dtype=np.float32), pd.DataFrame()

    x_list = []
    meta_rows = []

    with uproot.open(root_path) as f:
        tree = f[TREE_NAME]
        p0_name = f"p{detector}0"
        p1_name = f"p{detector}1"

        required = [p0_name, p1_name, "t00", "t01", "dc0", "dc1", "rms0", "rms1"]
        missing = [b for b in required if not branch_exists(tree, b)]
        if missing:
            raise KeyError(f"Faltan ramas en {root_path}: {missing}")

        meta_branches = [b for b in ["BE", "P1", "FM", "vts"] if branch_exists(tree, b)]
        branches = required + meta_branches

        first = int(selected_entries[0])
        last = int(selected_entries[-1]) + 1

        for start in range(first, last, CHUNK_SIZE):
            stop = min(start + CHUNK_SIZE, last)
            mask = (selected_entries >= start) & (selected_entries < stop)
            if not np.any(mask):
                continue

            local_entries = selected_entries[mask] - start
            arrays = tree.arrays(branches, library="ak", entry_start=start, entry_stop=stop)

            pulses0 = arrays[p0_name]
            pulses1 = arrays[p1_name]
            t00 = ak.to_numpy(arrays["t00"])
            t01 = ak.to_numpy(arrays["t01"])
            dc0 = ak.to_numpy(arrays["dc0"])
            dc1 = ak.to_numpy(arrays["dc1"])
            rms0 = ak.to_numpy(arrays["rms0"])
            rms1 = ak.to_numpy(arrays["rms1"])

            def meta_array(branch):
                return ak.to_numpy(arrays[branch]) if branch in meta_branches else np.full(len(t00), np.nan)

            be = meta_array("BE")
            p1_var = meta_array("P1")
            fm = meta_array("FM")
            vts = meta_array("vts")

            for loc in local_entries:
                loc = int(loc)
                global_entry = start + loc

                if not np.isfinite(t00[loc]) or not np.isfinite(t01[loc]):
                    continue

                p0_raw = ak.to_numpy(pulses0[loc]).astype(np.float32)
                p1_raw = ak.to_numpy(pulses1[loc]).astype(np.float32)

                if len(p0_raw) == 0 or len(p1_raw) == 0:
                    continue

                # Correccion de baseline y cambio de signo para que el pulso sea positivo.
                p0 = -(p0_raw - dc0[loc] / VSCALE)
                p1 = -(p1_raw - dc1[loc] / VSCALE)

                t00_pts = int(t00[loc] * SRATE)
                t01_pts = int(t01[loc] * SRATE)
                t0_pts = min(t00_pts, t01_pts)

                w0 = window_until_end(p0, t0_pts, pre_samples, rms0[loc] / VSCALE)
                w1 = window_until_end(p1, t0_pts, pre_samples, rms1[loc] / VSCALE)

                if NORM_METHOD == "max":
                    w0, w1 = normalize_pulses_max(w0, w1, pre_samples)
                else:
                    raise ValueError("NORM_METHOD no reconocido")

                w0 = downsample_waveform(w0)
                w1 = downsample_waveform(w1)

                x_list.append(np.stack([w0, w1], axis=1).astype(np.float32))
                meta_rows.append({
                    "entry": int(global_entry),
                    "detector": int(detector),
                    "BE": float(be[loc]),
                    "P1": float(p1_var[loc]),
                    "FM": float(fm[loc]),
                    "vts": float(vts[loc]),
                    "t00": float(t00[loc]),
                    "t01": float(t01[loc]),
                    "source_id": int(source["source_id"]),
                    "source_file": root_path.name,
                    "population": source["name"],
                })

    x = np.stack(x_list, axis=0).astype(np.float32) if x_list else np.empty((0, n_time, NUM_PMTS), dtype=np.float32)
    return x, pd.DataFrame(meta_rows)


