def compute_detector_weights(y_array, detector_array):
    # Dentro de cada clase, fuerza que todos los detectores tengan el mismo peso total.
    weights = np.ones_like(y_array, dtype=np.float32)
    y_int = y_array.astype(int)
    det_int = detector_array.astype(int)

    for label in np.unique(y_int):
        class_mask = y_int == label
        detectors = np.unique(det_int[class_mask])
        n_class = np.sum(class_mask)

        for det in detectors:
            mask = class_mask & (det_int == det)
            n_det = np.sum(mask)
            if n_det > 0:
                weights[mask] *= n_class / (len(detectors) * n_det)

    weights /= np.mean(weights)
    return weights.astype(np.float32)


sample_weight = compute_detector_weights(y, meta[:, 1])
strat_key = np.array([f"y{int(yy)}_D{int(dd)}_S{int(ss)}" for yy, dd, ss in zip(y, meta[:, 1], meta[:, 9])])

remaining_frac = VAL_FRAC + TEST_FRAC
val_fraction_of_remaining = VAL_FRAC / remaining_frac

x_train, x_tmp, y_train, y_tmp, meta_train, meta_tmp, w_train, w_tmp, strat_train, strat_tmp = train_test_split(
    x,
    y,
    meta,
    sample_weight,
    strat_key,
    train_size=TRAIN_FRAC,
    random_state=RANDOM_STATE,
    shuffle=True,
    stratify=strat_key,
)

x_val, x_test, y_val, y_test, meta_val, meta_test, w_val, w_test = train_test_split(
    x_tmp,
    y_tmp,
    meta_tmp,
    w_tmp,
    train_size=val_fraction_of_remaining,
    random_state=RANDOM_STATE,
    shuffle=True,
    stratify=strat_tmp,
)

