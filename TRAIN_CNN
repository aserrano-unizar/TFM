    pd.DataFrame(meta_split, columns=META_COLUMNS).to_csv(PRED_DIR / f"meta_{name}_{RUN_TAG}.tsv", sep="\t", index=False)

weights_summary = pd.DataFrame(meta, columns=META_COLUMNS)
weights_summary["label"] = weights_summary["label"].astype(int)
weights_summary["detector"] = weights_summary["detector"].astype(int)
weights_summary["source_id"] = weights_summary["source_id"].astype(int)
weights_summary["sample_weight"] = sample_weight
weights_summary = (
    weights_summary
    .groupby(["label", "source_id", "detector"])
    .agg(n=("sample_weight", "size"), weight_sum=("sample_weight", "sum"), weight_mean=("sample_weight", "mean"))
    .reset_index()
