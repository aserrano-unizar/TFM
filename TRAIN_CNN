print("Test: ", x_test.shape, y_test.shape, flush=True)


# ============================================================
# Modelo CNN pulse-only
# ============================================================

def build_cnn(input_shape):
    # Arquitectura convolucional dilatada inspirada en el codigo original de Ivan.
    pulse_input = layers.Input(shape=input_shape, name="pulse_input")

    conv1 = layers.Conv1D(FILTERS, KERNEL_SIZE, dilation_rate=1, padding="same", activation="relu", name="conv_dil1")(pulse_input)
    conv2 = layers.Conv1D(FILTERS, 2 * KERNEL_SIZE + 1, dilation_rate=2, padding="same", activation="relu", name="conv_dil2")(conv1)
    conv3 = layers.Conv1D(2 * FILTERS, 2 * KERNEL_SIZE + 1, dilation_rate=4, padding="same", activation="relu", name="conv_dil4")(conv2)
    conv4 = layers.Conv1D(2 * FILTERS, 2 * KERNEL_SIZE + 1, dilation_rate=8, padding="same", activation="relu", name="conv_dil8")(conv3)

    gap = layers.GlobalAveragePooling1D(name="global_average_pooling")(conv4)
    gmp = layers.GlobalMaxPooling1D(name="global_max_pooling")(conv4)
    features = layers.Concatenate(name="pulse_features")([gap, gmp])

    dense = layers.Dense(DENSE_UNITS, activation="relu", name="dense_features")(features)
    drop = layers.Dropout(DROPOUT, name="dropout")(dense)
    output = layers.Dense(1, activation="sigmoid", name="score")(drop)

    model = models.Model(inputs=pulse_input, outputs=output, name="cnn_pulse_only")
    model.compile(
        optimizer=optimizers.Adam(LEARNING_RATE),
        loss="binary_crossentropy",
        metrics=[tf.keras.metrics.AUC(name="auc"), "accuracy"],
    )
    return model


model = build_cnn(x_train.shape[1:])
model.summary()


# ============================================================
# Entrenamiento
# ============================================================

model_path = MODEL_DIR / f"modelo_pulse_only_{RUN_TAG}.keras"
history_path = LOG_DIR / f"history_pulse_only_{RUN_TAG}.csv"

callbacks = [
    TerminateOnNaN(),
    EarlyStopping(monitor="val_auc", mode="max", patience=PATIENCE, restore_best_weights=True, verbose=1),
    ModelCheckpoint(filepath=model_path, monitor="val_auc", mode="max", save_best_only=True, verbose=1),
    CSVLogger(history_path),
]

history = model.fit(
    x_train,
    y_train,
    sample_weight=w_train,
    validation_data=(x_val, y_val, w_val),
    epochs=EPOCHS,
    batch_size=BATCH_SIZE,
    callbacks=callbacks,
    verbose=1,
)

model.save(model_path)
with open(CONFIG_DIR / f"model_path_{RUN_TAG}.txt", "w", encoding="utf-8") as f:
    f.write(str(model_path))

print("Modelo guardado en:", model_path, flush=True)


