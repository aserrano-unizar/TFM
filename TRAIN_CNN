# Evaluacion y diagnosticos
# ============================================================

def evaluate_split(name, x_split, y_split, meta_split, weight_split):
    score = model.predict(x_split, batch_size=BATCH_SIZE, verbose=0).flatten()
    finite_score = np.isfinite(score)
    if not np.all(finite_score):
        raise ValueError(f"Hay scores no finitos en {name}")

    pred = (score >= SCORE_CUT).astype(int)
    fpr, tpr, _ = roc_curve(y_split, score)
    auc_value = auc(fpr, tpr)
    acc_value = accuracy_score(y_split, pred, sample_weight=weight_split)
    cm = confusion_matrix(y_split, pred)

    df = pd.DataFrame(meta_split, columns=META_COLUMNS)
    df["score"] = score
    df["prediction"] = pred
    df["sample_weight"] = weight_split
    df.to_csv(PRED_DIR / f"predicciones_{name}_pulse_only_{RUN_TAG}.tsv", sep="\t", index=False)

    fig, ax = plt.subplots(figsize=(6, 5))
    ax.plot(fpr, tpr, label=f"AUC = {auc_value:.4f}")
    ax.plot([0, 1], [0, 1], "--", color="gray")
    ax.set_xlabel("False positive rate")
    ax.set_ylabel("True positive rate")
    ax.set_title(f"ROC {name}")
    ax.grid(alpha=0.3)
    ax.legend()
    fig.tight_layout()
    fig.savefig(FIG_DIR / f"roc_{name}_pulse_only_{RUN_TAG}.png", dpi=200)
    plt.close(fig)

    fig, ax = plt.subplots(figsize=(7, 5))
    ax.hist(score[y_split == 0], bins=50, histtype="step", density=True, label="y=0")
    ax.hist(score[y_split == 1], bins=50, histtype="step", density=True, label="y=1")
    ax.set_xlabel("score CNN")
    ax.set_ylabel("densidad")
    ax.set_title(f"Distribucion de score {name}")
    ax.grid(alpha=0.3)
    ax.legend()
    fig.tight_layout()
    fig.savefig(FIG_DIR / f"score_hist_{name}_pulse_only_{RUN_TAG}.png", dpi=200)
    plt.close(fig)

    return {
        "split": name,
        "auc": auc_value,
        "accuracy": acc_value,
        "n": len(y_split),
        "cm": cm,
    }


metrics = [
